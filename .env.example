# DATA RÉNO Pipeline — variables d'environnement (copier vers .env, ne jamais committer .env)
# Renseigner au fil des phases. Aucune valeur en dur dans le code.

# --- CTA / liens (Phases 3-4) ---
CALENDLY_URL=
OPTOUT_URL=

# --- Domaine & envoi (Phases 4-5) ---
SENDING_DOMAIN=
# Mode de génération des brouillons : "gmail" (Workspace) ou "esp" (export mailmerge CSV)
DRAFT_MODE=esp

# --- Réassurance (Phase 3, affichée dans les mails) ---
REASSURANCE_RGE=
REASSURANCE_DECENNALE=
REASSURANCE_NB_CHANTIERS=

# --- État local ---
DB_PATH=state.sqlite

# --- Warm-up séquence (Phase 5) ---
WARMUP_J1=30
WARMUP_J2=50
WARMUP_MAX=100
