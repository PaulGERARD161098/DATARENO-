# DATA RÉNO Pipeline — variables d'environnement (copier vers .env, ne jamais committer .env)
# Renseigner au fil des phases. Aucune valeur en dur dans le code.

# --- CTA / liens / expéditeur (Phases 3-4) ---
CALENDLY_URL=
OPTOUT_URL=
SENDER_NAME=
# Token API Calendly (Personal Access Token) pour remonter les RDV pris → event 'rdv'.
CALENDLY_TOKEN=

# --- Domaine & envoi (Phases 4-5) ---
SENDING_DOMAIN=

# --- Réassurance (Phase 3, affichée dans les mails) ---
REASSURANCE_RGE=
REASSURANCE_DECENNALE=
REASSURANCE_NB_CHANTIERS=

# --- État local ---
DB_PATH=state.sqlite

# --- Panneau de pilotage web (src.web) ---
# Auth Basic du panneau. OBLIGATOIRE dès qu'il est exposé via un tunnel (PII).
# Laisser vide = pas d'auth (uniquement acceptable en localhost pur).
WEB_USER=
WEB_PASSWORD=

# --- Warm-up séquence (Phase 5) ---
WARMUP_J1=30
WARMUP_J2=50
WARMUP_MAX=100

# --- Garde-fou délivrabilité (Phase 8) ---
# Coupe-circuit : au-delà de ce taux de bounce (sur l'historique d'envoi), send_due
# refuse d'envoyer. 0.05 = 5 %. Ne s'active qu'au-delà d'un échantillon minimal.
BOUNCE_RATE_LIMIT=0.05

# --- Transport SMTP du domaine dédié (envoi réel) ---
# Renseigner SEULEMENT au moment de brancher l'envoi réel. Jamais en dur dans le code.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
# Adresse expéditrice (mailbox réelle du domaine dédié). Défaut: contact@SENDING_DOMAIN.
SENDER_EMAIL=
# Adresse mailto de désinscription (header List-Unsubscribe). Défaut: unsubscribe@SENDING_DOMAIN.
UNSUBSCRIBE_MAILTO=

# --- Ingestion des retours par IMAP (poll de la boîte du domaine dédié) ---
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
# Dossier à relever (défaut INBOX).
IMAP_FOLDER=INBOX
