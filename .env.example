# DATA RÉNO Pipeline — variables d'environnement (copier vers .env, ne jamais committer .env)
# Renseigner au fil des phases. Aucune valeur en dur dans le code.

# --- CTA / liens / expéditeur (Phases 3-4) ---
CALENDLY_URL=
OPTOUT_URL=
SENDER_NAME=

# --- Domaine & envoi (Phases 4-5) ---
SENDING_DOMAIN=
# Mode de génération des brouillons : "gmail" (Workspace) ou "esp" (export mailmerge CSV)
DRAFT_MODE=esp

# --- Réassurance (Phase 3, affichée dans les mails) ---
REASSURANCE_RGE=
REASSURANCE_DECENNALE=
REASSURANCE_NB_CHANTIERS=

# --- État local ---
DB_PATH=state.sqlite

# --- Warm-up séquence (Phase 5) ---
WARMUP_J1=30
WARMUP_J2=50
WARMUP_MAX=100

# --- Envoi SMTP du domaine dédié (Phase 8 — secrets, ne jamais committer) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Expéditeur affiché, ex: "Paul Gérard <contact@domaine-dedie.fr>"
SMTP_FROM=
# Mettre 1 pour SMTPS direct (port 465) ; sinon STARTTLS sur 587
SMTP_SSL=0
